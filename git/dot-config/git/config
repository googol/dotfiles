[user]
    name = Miika Hänninen
    email = miika@miikahanninen.com
[core]
    # excludesfile = ~/.gitignore_global
    editor = vim
    pager = delta
[push]
    default = simple
    autoSetupRemote = true
[pull]
    ff = only
    twohead = ort
[alias]
    statsu=status
    stauts=status
    ll = !exec git log --pretty='format: %C(auto) %h %d %s' --abbrev-commit --graph --decorate --all --color | less -R -p 'HEAD ->'
    fp = push --force-with-lease
    fixup = commit --amend --no-edit
    ps=push
    pl=pull
    b=branch
    co=checkout
    ci=commit
    d=diff
    dd=diff --cached
    dt=difftool
    ddt=difftool --cached
    l=log
    a=add
    ft=fetch
    rb=rebase
    g=grep -i -n
    git = !exec git
    bc= !exec branch-cleanup
    hub = !exec github-open.sh
    hub-branch = !exec github-open.sh branch
    hub-pulls = !exec github-open.sh pulls
[diff]
    algorithm = histogram
    submodule = log
    colorMoved = plain
    mnemonicPrefix = true
    renames = true
[column]
    ui = auto
[difftool]
    prompt = false
[commit]
    verbose = true
#    gpgsign = true
[merge]
    conflictstyle = zdiff3
    ff = false
[branch]
    sort = -committerdate
[tag]
    sort = version:refname
[fetch]
    recurseSubmodules = on-demand
    prune = true
    pruneTags = true
    all = true
[status]
    submoduleSummary = true
[rebase]
    autoSquash = true
    updateRefs = true
[advice]
    skippedCherryPicks = false
[init]
    defaultBranch = main
[log]
    date = iso
[interactive]
    diffFilter = delta --color-only
[help]
    autocorrect = prompt
[includeIf "gitdir:~/src/relex/"]
    path = ~/.config/git/relex.config
[includeIf "gitdir:~/src/github.com/partio-scout/"]
    path = ~/.config/git/partio.config
[includeIf "gitdir:~/src/starcart/"]
    path = ~/.config/git/starcart.config
[includeIf "gitdir:~/src/sok/"]
    path = ~/.config/git/sok.config
[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
