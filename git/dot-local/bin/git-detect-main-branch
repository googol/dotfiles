#!/usr/bin/env bash

main() {
  if branch_exists "master"; then
    echo "master"
  elif branch_exists "main"; then
    echo "main"
  else
    return 1
  fi
}

branch_exists() {
  local -r branch_name="$1"

  output="$(git branch --list "$branch_name")"
  if [[ ! -z "$output" ]]; then
    return 0
  else
    return 1
  fi
}

main
